<Window x:Class="FleetManager.AdminPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panneau d'Administration" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="👑 Panneau d'Administration" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock x:Name="AdminNameText" Text="" FontSize="14" Margin="20,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
        </StackPanel>

        <!-- Statistiques et bouton d'ajout -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Stats -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border Background="#E3F2FD" Padding="15,10" CornerRadius="5" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Total utilisateurs" FontSize="12" Foreground="Gray"/>
                        <TextBlock x:Name="TotalUsersText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#1976D2"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFF3E0" Padding="15,10" CornerRadius="5" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Agents" FontSize="12" Foreground="Gray"/>
                        <TextBlock x:Name="AgentsText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#F57C00"/>
                    </StackPanel>
                </Border>
                <Border Background="#E8F5E9" Padding="15,10" CornerRadius="5" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Clients actifs" FontSize="12" Foreground="Gray"/>
                        <TextBlock x:Name="ActiveClientsText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#388E3C"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFEBEE" Padding="15,10" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="Comptes bloqués" FontSize="12" Foreground="Gray"/>
                        <TextBlock x:Name="BlockedUsersText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#D32F2F"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Bouton ajout agent/client -->
            <Button Grid.Column="1" Content="➕ Ajouter un utilisateur" Click="AddUser_Click" 
                    Padding="15,10" Background="#4CAF50" Foreground="White" BorderThickness="0" 
                    FontWeight="Bold" Cursor="Hand"/>
        </Grid>

        <!-- Liste des utilisateurs -->
        <DataGrid x:Name="UsersDataGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False"
                  SelectionMode="Single" IsReadOnly="True" AlternatingRowBackground="LightGray"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="120"/>
                <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                <DataGridTextColumn Header="Rôle" Binding="{Binding Role}" Width="80"/>
                <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="80"/>
                <DataGridTemplateColumn Header="Actions" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="👑 Admin" Click="PromoteToAdmin_Click" Tag="{Binding Id}"
                                        Margin="2" Padding="5,2" Background="#4CAF50" Foreground="White" BorderThickness="0"/>
                                <Button Content="🔧 Agent" Click="PromoteToAgent_Click" Tag="{Binding Id}"
                                        Margin="2" Padding="5,2" Background="#FF9800" Foreground="White" BorderThickness="0"/>
                                <Button Content="👤 Client" Click="DemoteToClient_Click" Tag="{Binding Id}"
                                        Margin="2" Padding="5,2" Background="#2196F3" Foreground="White" BorderThickness="0"/>
                                <Button Content="⛔ Bloquer" Click="BlockUser_Click" Tag="{Binding Id}"
                                        Margin="2" Padding="5,2" Background="#F44336" Foreground="White" BorderThickness="0"/>
                                <Button Content="✅ Débloquer" Click="UnblockUser_Click" Tag="{Binding Id}"
                                        Margin="2" Padding="5,2" Background="#00BCD4" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Boutons en bas -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="🔄 Actualiser" Click="RefreshButton_Click" Width="120" Margin="5" Padding="8"/>
            <Button Content="🏪 Voir la boutique" Click="ViewShop_Click" Width="140" Margin="5" Padding="8"/>
            <Button Content="🚪 Déconnexion" Click="LogoutButton_Click" Width="120" Margin="5" Padding="8"/>
        </StackPanel>
    </Grid>
</Window>