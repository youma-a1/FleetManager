<Window x:Class="FleetManager.AdminPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panneau d'Administration" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0" Background="#1976D2" Padding="20,15">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="👨‍💼 Panneau d'Administration" 
                               FontSize="24" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="AdminNameText" Text="Connecté : Admin" 
                               FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button Content="🔄 Actualiser" Click="RefreshButton_Click"
                            Padding="12,8" Margin="0,0,10,0" Background="#4CAF50" 
                            Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="🚪 Déconnexion" Click="LogoutButton_Click"
                            Padding="12,8" Background="#F44336" 
                            Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Statistiques rapides + Boutons d'actions -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="20,15" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Statistiques -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="8" Margin="0,0,10,0" 
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="👥 Total utilisateurs" FontSize="12" Foreground="Gray"/>
                            <TextBlock x:Name="TotalUsersText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#2196F3"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" Padding="15" CornerRadius="8" Margin="0,0,10,0"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="👷 Agents" FontSize="12" Foreground="Gray"/>
                            <TextBlock x:Name="AgentsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#FF9800"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="White" Padding="15" CornerRadius="8" Margin="0,0,10,0"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="👤 Clients actifs" FontSize="12" Foreground="Gray"/>
                            <TextBlock x:Name="ActiveClientsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#4CAF50"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Background="White" Padding="15" CornerRadius="8"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="🚫 Comptes bloqués" FontSize="12" Foreground="Gray"/>
                            <TextBlock x:Name="BlockedAccountsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#F44336"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Boutons d'actions -->
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button Content="➕ Ajouter un utilisateur" Click="AddUserButton_Click"
                            Padding="15,10" Margin="0,0,10,0" Background="#4CAF50" 
                            Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                    <Button Content="📊 Statistiques véhicules" Click="ShowStatistics_Click"
                            Padding="15,10" Background="#2196F3" 
                            Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Liste des utilisateurs -->
        <DataGrid Grid.Row="2" x:Name="UsersDataGrid" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False" 
                  IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  Margin="20">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="150"/>
                <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="150"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="250"/>
                <DataGridTextColumn Header="Rôle" Binding="{Binding Role}" Width="120"/>
                <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="100"/>

                <DataGridTemplateColumn Header="Actions" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <!-- Promouvoir Admin -->
                                <Button Content="👑 Admin" Click="PromoteToAdmin_Click"
                                        Tag="{Binding Id}"
                                        Padding="8,5" Margin="0,0,5,0"
                                        Background="#4CAF50" Foreground="White" 
                                        BorderThickness="0" FontSize="11" Cursor="Hand"/>

                                <!-- Promouvoir Agent -->
                                <Button Content="👷 Agent" Click="PromoteToAgent_Click"
                                        Tag="{Binding Id}"
                                        Padding="8,5" Margin="0,0,5,0"
                                        Background="#FF9800" Foreground="White" 
                                        BorderThickness="0" FontSize="11" Cursor="Hand"/>

                                <!-- Rétrograder Client -->
                                <Button Content="👤 Client" Click="DemoteToClient_Click"
                                        Tag="{Binding Id}"
                                        Padding="8,5" Margin="0,0,5,0"
                                        Background="#2196F3" Foreground="White" 
                                        BorderThickness="0" FontSize="11" Cursor="Hand"/>

                                <!-- Bloquer -->
                                <Button Content="🚫 Bloquer" Click="BlockUser_Click"
                                        Tag="{Binding Id}"
                                        Padding="8,5" Margin="0,0,5,0"
                                        Background="#F44336" Foreground="White" 
                                        BorderThickness="0" FontSize="11" Cursor="Hand"/>

                                <!-- Débloquer -->
                                <Button Content="✅ Débloquer" Click="UnblockUser_Click"
                                        Tag="{Binding Id}"
                                        Padding="8,5"
                                        Background="#00BCD4" Foreground="White" 
                                        BorderThickness="0" FontSize="11" Cursor="Hand"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>