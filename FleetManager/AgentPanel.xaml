<Window x:Class="FleetManager.AgentPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panneau Agent" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="🔧 Panneau Agent" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock x:Name="AgentNameText" Text="" FontSize="14" Margin="20,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
        </StackPanel>

        <!-- Statistiques et actions -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Stats -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border Background="#E3F2FD" Padding="15,10" CornerRadius="5" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Véhicules totaux" FontSize="12" Foreground="Gray"/>
                        <TextBlock x:Name="TotalVehiclesText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#1976D2"/>
                    </StackPanel>
                </Border>
                <Border Background="#E8F5E9" Padding="15,10" CornerRadius="5" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Véhicules actifs" FontSize="12" Foreground="Gray"/>
                        <TextBlock x:Name="ActiveVehiclesText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#388E3C"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFF3E0" Padding="15,10" CornerRadius="5" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Clients connectés" FontSize="12" Foreground="Gray"/>
                        <TextBlock x:Name="ConnectedClientsText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#F57C00"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Boutons actions -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="➕ Ajouter véhicule" Click="AddVehicle_Click" 
                        Padding="15,10" Background="#4CAF50" Foreground="White" 
                        BorderThickness="0" FontWeight="Bold" Cursor="Hand" Margin="0,0,10,0"/>
                <Button Content="📊 Statistiques" Click="ShowStatistics_Click" 
                        Padding="15,10" Background="#2196F3" Foreground="White" 
                        BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- Liste des véhicules -->
        <DataGrid x:Name="VehiclesDataGrid" Grid.Row="2" AutoGenerateColumns="False" 
                  CanUserAddRows="False" SelectionMode="Single" IsReadOnly="True"
                  AlternatingRowBackground="LightGray" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTemplateColumn Header="Image" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding ImageUrl}" Width="60" Height="40" Stretch="UniformToFill" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Marque" Binding="{Binding Marque}" Width="120"/>
                <DataGridTextColumn Header="Modèle" Binding="{Binding Modele}" Width="120"/>
                <DataGridTextColumn Header="Immatriculation" Binding="{Binding Immatriculation}" Width="120"/>
                <DataGridTextColumn Header="Carburant" Binding="{Binding Carburant}" Width="100"/>
                <DataGridTextColumn Header="Kilométrage" Binding="{Binding Kilometrage}" Width="100"/>
                <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="100"/>
                <DataGridTemplateColumn Header="Actions" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="✏️ Modifier" Click="EditVehicle_Click" Tag="{Binding Id}"
                                        Margin="2" Padding="5,2" Background="#FF9800" Foreground="White" BorderThickness="0"/>
                                <Button Content="📈 MAJ KM" Click="UpdateKm_Click" Tag="{Binding Id}"
                                        Margin="2" Padding="5,2" Background="#2196F3" Foreground="White" BorderThickness="0"/>
                                <Button Content="🗑️ Supprimer" Click="DeleteVehicle_Click" Tag="{Binding Id}"
                                        Margin="2" Padding="5,2" Background="#F44336" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Boutons en bas -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="🔄 Actualiser" Click="RefreshButton_Click" Width="120" Margin="5" Padding="8"/>
            <Button Content="👥 Voir clients" Click="ViewClients_Click" Width="130" Margin="5" Padding="8"/>
            <Button Content="🚪 Déconnexion" Click="LogoutButton_Click" Width="120" Margin="5" Padding="8"/>
        </StackPanel>
    </Grid>
</Window>