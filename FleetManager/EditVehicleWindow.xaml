<Window x:Class="FleetManager.EditVehicleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modifier un véhicule" Height="600" Width="550"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Zone avec scroll -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <!-- Titre -->
                <TextBlock Text="✏️ Modifier le véhicule" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                <!-- Marque -->
                <TextBlock Text="Marque :" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="MarqueTextBox" Padding="8" FontSize="14" Margin="0,0,0,10"/>

                <!-- Modèle -->
                <TextBlock Text="Modèle :" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="ModeleTextBox" Padding="8" FontSize="14" Margin="0,0,0,10"/>

                <!-- Immatriculation -->
                <TextBlock Text="Immatriculation :" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="ImmatriculationTextBox" Padding="8" FontSize="14" CharacterCasing="Upper" Margin="0,0,0,10"/>

                <!-- Carburant -->
                <TextBlock Text="Carburant :" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="CarburantComboBox" Padding="8" FontSize="14" Margin="0,0,0,10">
                    <ComboBoxItem Content="Essence"/>
                    <ComboBoxItem Content="Diesel"/>
                    <ComboBoxItem Content="Électrique"/>
                    <ComboBoxItem Content="Hybride"/>
                    <ComboBoxItem Content="GPL"/>
                </ComboBox>

                <!-- Consommation moyenne -->
                <TextBlock Text="Consommation moyenne (L/100km) :" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="ConsommationTextBox" Padding="8" FontSize="14" Margin="0,0,0,10"/>

                <!-- Statut -->
                <TextBlock Text="Statut :" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="StatutComboBox" Padding="8" FontSize="14" Margin="0,0,0,10">
                    <ComboBoxItem Content="actif"/>
                    <ComboBoxItem Content="en_panne"/>
                    <ComboBoxItem Content="en_maintenance"/>
                    <ComboBoxItem Content="retire"/>
                </ComboBox>

                <!-- Date d'achat -->
                <TextBlock Text="Date d'achat :" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <DatePicker x:Name="DateAchatPicker" Padding="8" FontSize="14" Margin="0,0,0,10"/>

                <!-- Image du véhicule -->
                <TextBlock Text="Changer l'image :" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ImagePathTextBox" Grid.Column="0" Padding="8" FontSize="14" IsReadOnly="True" Background="#F5F5F5"/>
                    <Button Grid.Column="1" Content="📁 Parcourir" Click="BrowseImage_Click"
                            Padding="10,8" Margin="5,0,0,0" Background="#2196F3" Foreground="White" BorderThickness="0"/>
                </Grid>

                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" 
                        Width="200" Height="150" HorizontalAlignment="Left" Margin="0,0,0,10">
                    <Image x:Name="PreviewImage" Stretch="Uniform" Margin="5"/>
                </Border>

                <!-- Message d'erreur -->
                <TextBlock x:Name="ErrorTextBlock" Text="" Foreground="Red" TextWrapping="Wrap" Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Boutons FIXES en bas -->
        <Border Grid.Row="1" Background="White" BorderBrush="LightGray" BorderThickness="0,1,0,0" Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="💾 Sauvegarder" Click="SaveButton_Click" 
                        Width="130" Margin="0,0,10,0"
                        Padding="10,8" Background="#4CAF50" Foreground="White" 
                        BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                <Button Content="❌ Annuler" Click="CancelButton_Click" 
                        Width="120"
                        Padding="10,8" Background="#9E9E9E" Foreground="White" 
                        BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>